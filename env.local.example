# Copy this file to `.env.local` in the project root (same folder as `package.json`).
# Never commit `.env.local` to git.

# --- Required for any database access ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Required for server writes (bookings, Stripe webhook, contact form) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (Stripe redirects, emails) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (booking deposits) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Optional media (future uploads) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
