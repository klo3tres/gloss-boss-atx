# Copy this file to `.env.local` in the project root (same folder as `package.json`).
# Never commit `.env.local` to git.

# --- Required for any database access ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Required for server writes (bookings, Stripe webhook, contact form) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (Stripe redirects, emails) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron (Vercel scheduled jobs: /api/cron/*) ---
CRON_SECRET=

# --- Stripe (booking deposits) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Weather and dispatch ---
OPENWEATHER_API_KEY=
BUSINESS_HOME_BASE_ADDRESS=
BUSINESS_LAT=
BUSINESS_LNG=

# --- Titan Lead Radar (Google Places discovery) ---
GOOGLE_PLACES_API_KEY=
# Optional: override discovery radius (default 15 miles)
TITAN_DISCOVERY_RADIUS_MILES=15

# Suppresses only the false Twilio 30032 verification warning; real failures remain visible.
TWILIO_TOLLFREE_VERIFIED=false

# --- Optional media (future uploads) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
