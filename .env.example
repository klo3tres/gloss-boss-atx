NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Google Places — required for review sync + Lead Radar discovery
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional — GA4 Data API (service account) for Website Intelligence traffic metrics
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CLIENT_EMAIL=
GOOGLE_ANALYTICS_PRIVATE_KEY=
# Optional — Microsoft Clarity API (script uses workspace ID by default)
CLARITY_PROJECT_ID=
CLARITY_API_TOKEN=
# Optional — future Search Console API
GOOGLE_SEARCH_CONSOLE_SITE_URL=
# Web push (staff browser notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@yourdomain.com
# Optional — Pushover for owner + per-staff phone push (staff adds user key in /tech/settings)
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
# Email (Resend) + SMS (Twilio) — required for staff alerts
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
