{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.glossbossatx.com" }],
      "destination": "https://glossbossatx.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-exceptions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/process-follow-ups",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/titan-nightly",
      "schedule": "0 6 * * *"
    }
  ]
}
