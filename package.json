{
  "name": "gloss-boss-atx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-build-artifacts.cjs",
    "cache:clean": "node scripts/clean-build-artifacts.cjs",
    "deep:clean": "npm run clean",
    "free:port": "node scripts/free-default-port.cjs",
    "predev": "node scripts/free-default-port.cjs",
    "dev": "next dev -p 3000",
