# Copy to `.env.local` (project root). See also `env.local.example`.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Resend — outbound + inbound (info@glossbossatx.com → CRM + forward to Gmail)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=info@glossbossatx.com
# RESEND_WEBHOOK_SECRET=whsec_...   # Resend signing secret — ONE webhook: /api/resend/webhook
# INBOUND_MAILBOX_EMAIL=info@glossbossatx.com
# INBOUND_FORWARD_TO=glossbossatx1@gmail.com
# CONTACT_NOTIFY_EMAIL=glossbossatx1@gmail.com   # website contact form + fallback forward target
# BUSINESS_NOTIFY_EMAIL=ops@yourdomain.com  # optional; falls back to CONTACT_NOTIFY_EMAIL

# Optional: Twilio SMS — prefer Messaging Service SID; TWILIO_FROM_NUMBER is fallback
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=
